{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "billingPolicy.ts",
        "config/index.ts",
        "config/vars.ts",
        "dlpPolicy.ts",
        "environmentBackup.ts",
        "environmentGroup.ts",
        "getApps.ts",
        "getConnectors.ts",
        "getEnvironments.ts",
        "getFlows.ts",
        "index.ts",
        "isvContract.ts",
        "managedEnvironment.ts",
        "provider.ts",
        "roleAssignment.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "utilities.ts"
    ]
}
